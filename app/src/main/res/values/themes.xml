<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ShopVerse" parent="Theme.MaterialComponents.DayNight.NoActionBar" />

    <!-- *************************** BottomSheet Dialog Styles *************************************
                            It will apply on all BottomSheetDialogs
    ******************************************************************************************** -->
    <style name="AppBottomSheetDialogTheme" parent="@style/Theme.Design.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/RoundedBottomSheet</item>
        <!-- Navigation bar color. -->
        <item name="android:windowIsFloating">false</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <!-- Edit text Auto fill-->
        <item name="android:autofilledHighlight" tools:targetApi="o">@android:color/transparent
        </item>
    </style>

    <style name="RoundedBottomSheet" parent="Theme.Design.BottomSheetDialog">
        <item name="shapeAppearanceOverlay">@style/roundedShapeAppearanceBottomSheetDialog</item>
    </style>

    <style name="roundedShapeAppearanceBottomSheetDialog">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>
</resources>
